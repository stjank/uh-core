#!/bin/sh

TESTING_BASE_DIR="@CMAKE_CURRENT_SOURCE_DIR@"
TESTING_BINARY_DIR="@CMAKE_CURRENT_BINARY_DIR@"
PYTHON3="@Python3_EXECUTABLE@"
venv_dir="@TESTING_VENV_DIR@"
requirements_file="$TESTING_BASE_DIR/python-requirements.txt"
AWS_ACCESS_KEY_ID="aws_access_key_id"
AWS_SECRET_ACCESS_KEY="aws_secret_access_key"

set -e

cluster_url=""

print_help()
{
    echo "start-e2e.sh [options] -- [py_test options]"
    echo
    echo "options are:"
    echo " -h, --help           print this text"
    echo " -u URL, --url URL    run tests against an existing cluster"
}

while [ -n "$1" ]; do
    if [ "$1" = "--" ]; then
        shift
        break
    fi

    case "$1" in
        -h|--help)  print_help
                    exit 0
                    ;;
        -u|--url)   shift
                    cluster_url="$1"
                    case "$cluster_url" in
                        http://*);;
                        *) cluster_url="http://$cluster_url";;
                    esac
                    ;;
    esac

    shift
done


if [ ! -d "$venv_dir" ] || [ "$venv_dir" -ot "$requirements_file" ]; then
    echo "Creating virtual environment ..."

    $PYTHON3 -m venv "$venv_dir"

    . "$venv_dir/bin/activate"

    pip --require-virtualenv install --requirement "$requirements_file" || {
        deactivate
        rm -rf "$venv_dir"
        exit 1
    }

    deactivate
    touch "$venv_dir"
fi

. "$venv_dir/bin/activate"


set +e

compose_file="$TESTING_BINARY_DIR/docker-compose.yml"
use_docker_compose="0"
if [ -z "$cluster_url" ]; then
    if [ ! -e "$compose_file" ]; then
        echo "Compose file was not generated. Do you have docker installed?"
        echo
        echo "Install docker and enable it for this user. Then run cmake again."
        echo "You can also start the cluster yourself and reference it using "
        echo "--url <cluster-url>"
        exit 1
    fi

    docker-compose -f "$compose_file" up --detach
    cluster_url="http://localhost:8080"
    use_docker_compose="1"
fi

timeout=30
while [ "$timeout" -gt "0" ]; do

    if curl --silent --output /dev/null $cluster_url; then
        break
    fi

    timeout=$((timeout - 1))
    sleep 1
done

if [ "$timeout" -eq "0" ]; then
    echo "connection to cluster URL failed"
    exit 1
fi

export PYTHONDONTWRITEBYTECODE=1
pytest "$TESTING_BINARY_DIR/tests" --cluster-url="$cluster_url" \
    --aws-access-key-id="$AWS_ACCESS_KEY_ID" --aws-secret-access-key="$AWS_SECRET_ACCESS_KEY" $@

if [ "$use_docker_compose" -eq "1" ]; then
    docker-compose -f "$TESTING_BINARY_DIR/docker-compose.yml" down
fi
