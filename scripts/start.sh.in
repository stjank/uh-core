#!/bin/bash

dedup=1
storage_cfg='[{"id":0,"type":"ROUND_ROBIN","storages":1}]'

while [[ $# -gt 0 ]]; do
    case "$1" in
        -d|--dedup)
            dedup="$2"
            shift 2
            ;;
        -s|--storage-cfg)
            storage_cfg="$2"
            shift 2
            ;;
        *)
            echo "Unknown option: $1"
            exit 1
            ;;
    esac
done

UH_LICENSE=$(<@PROJECT_SOURCE_DIR@/data/licenses/UltiHash-Test-1PB.lic)
BUILD_DIR=@PROJECT_BINARY_DIR@
UH_DATA=/var/lib/uh
export UH_LOG_LEVEL=DEBUG
UH_CLUSTER=$<TARGET_FILE:uh-cluster>
log_dir=$BUILD_DIR/logs
if [[ -d "$log_dir" ]]; then
    rm -f "$log_dir"/*
fi
mkdir -p $log_dir

parse_json_by_type() {
    local json="$1"
    echo "$json" | jq -c '.[]' | while read -r item; do
        id=$(echo "$item" | jq -r '.id')
        type=$(echo "$item" | jq -r '.type')
        storages=$(echo "$item" | jq -r '.storages')

        echo "ID: $id"
        echo "Type: $type"
        echo "Storages: $storages"

        if [[ "$type" == "ERASURE_CODING" ]]; then
            data_shards=$(echo "$item" | jq -r '.data_shards')
            parity_shards=$(echo "$item" | jq -r '.parity_shards')
            stripe_size_kib=$(echo "$item" | jq -r '.stripe_size_kib')
            echo "  Data Shards: $data_shards"
            echo "  Parity Shards: $parity_shards"
            echo "  Stripe Size (KiB): $stripe_size_kib"
        fi

        export OTEL_RESOURCE_ATTRIBUTES="service.name=storage"
        for ((storage_id = 0; storage_id < $storages; ++storage_id)); do
            data_path=$UH_DATA/storage-$id-$storage_id
            port=$((9300 + id * 10 + storage_id))
            echo " Storage port: $port"
            mkdir -p $data_path
            UH_STORAGE_GROUP_ID=$id UH_STORAGE_INSTANCE_ID=$storage_id $UH_CLUSTER --workdir $data_path storage --port $port &> $log_dir/storage-$id-$storage_id.log &
        done
    done
}

set -e

echo "*** resetting database"
$BUILD_DIR/scripts/reset-db.sh

echo "*** removing old UH data"
rm --recursive --force --verbose $UH_DATA/*

echo "*** wipe etcd data"
ETCDCTL_API=3 etcdctl del --from-key /

echo "*** starting services"
export TSAN_OPTIONS="detect_odr_violation=0,suppressions=@PROJECT_SOURCE_DIR@/tsan-suppressions"

if [[ -n "$storage_cfg" ]]; then
    echo "Parsing storage configuration JSON..."
    parse_json_by_type "$storage_cfg"
fi

export UH_STORAGE_GROUPS="$storage_cfg"

echo "UH_STORAGE_GROUPS has been set to:"
echo "$UH_STORAGE_GROUPS"

export OTEL_RESOURCE_ATTRIBUTES="service.name=coordinator"
$UH_CLUSTER coordinator &> $log_dir/coordinator.log &

export OTEL_RESOURCE_ATTRIBUTES="service.name=deduplicator"
for ((id = 0; id < $dedup; ++id)); do
    mkdir -p $UH_DATA/deduplicator-$id
    $UH_CLUSTER --workdir $UH_DATA/deduplicator-$id deduplicator --port $((9200 + id)) &> $log_dir/deduplicator-$id.log &
done

export OTEL_RESOURCE_ATTRIBUTES="service.name=entrypoint"
$UH_CLUSTER entrypoint &> $log_dir/entrypoint.log &

get_running_processes() {
    ps -eo pid,cmd | grep -E '^\s*[0-9]+\s+\S*uh-cluster' | sed 's/\S*uh-cluster/uh-cluster/'
}

echo "All services are running. Log files are written $log_dir and will"
echo "not be removed after the script has finished."
echo
get_running_processes
echo
echo "Hit <Return> to kill all spawned processes and shutdown the cluster."

notify_path=$(which notify-send)
if [ -x "$notify_path" ]; then
    $notify_path --expire-time=3000 'UH cluster is running'
fi

read

echo "Killing all spawned processes..."
pkill uh-cluster

sleep 0.3 

if pgrep -x "uh-cluster" > /dev/null; then
    echo
    echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    echo " More than one uh-cluster process is still running "
    echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    echo
    get_running_processes
fi
